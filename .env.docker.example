# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:ChangeThisPassword@postgres:5432/app_db
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeThisPassword

# ── Auth ──────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_EXPIRE_MINUTES=1440

# ── Frontend ──────────────────────────────────────────────
APP_BASE_URL=http://localhost:9600

# ── Anthropic Claude ──────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
